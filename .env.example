# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LOCAL_ONLY_MODE=true

# API
DATABASE_URL=postgresql+psycopg2://video:video@db:5432/video
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
LOCAL_ONLY_MODE=true
LOCAL_ADMIN_EMAIL=admin
LOCAL_ADMIN_PASSWORD=admin
STORAGE_DIR=/data/storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
TRANSCRIPTION_BACKEND=server
# Server transcription model: faster-whisper models plus nvidia/parakeet-tdt-0.6b-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
# Desktop-only MLX Audio default model
MLX_AUDIO_MODEL=mlx-community/parakeet-tdt-0.6b-v3
OLLAMA_BASE_URL=http://127.0.0.1:11434
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LOCAL_ENGINE_TIMEOUT_SECONDS=0.75
