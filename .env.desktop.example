DESKTOP_APP_NAME=Sparks Coach
DESKTOP_API_HOST=127.0.0.1
DESKTOP_API_PORT=18000
DESKTOP_WEB_HOST=127.0.0.1
DESKTOP_WEB_PORT=13000
NEXT_PUBLIC_API_URL=http://127.0.0.1:18000
LOCAL_ONLY_MODE=true
LOCAL_ADMIN_EMAIL=admin
LOCAL_ADMIN_PASSWORD=admin
TRANSCRIPTION_BACKEND=server
# Server fallback transcription model: faster-whisper models plus nvidia/parakeet-tdt-0.6b-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
# Optional MLX Audio model when you explicitly switch backends
MLX_AUDIO_MODEL=mlx-community/parakeet-tdt-0.6b-v3
OLLAMA_BASE_URL=http://127.0.0.1:11434
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
LOCAL_ENGINE_TIMEOUT_SECONDS=0.75
